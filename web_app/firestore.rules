rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 유저별 데이터 격리 규칙
    match /users/{userId} {
      // 본인만 자신의 유저 문서 및 하위 컬렉션에 접근 가능
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // 하위 모든 컬렉션(assets, transactions, settings, snapshots 등)에 동일 규칙 적용
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 기본적으로 모든 접근 차단 (Whitelisting 방식)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
